{
  "name": "@instantautotraders/seo-automation",
  "version": "2.0.0",
  "description": "Comprehensive SEO automation and monitoring tool for WordPress sites",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/index.js",
    "monitor": "node src/monitoring/monitor-rankings.js",
    "monitor:dashboard": "node src/monitoring/dashboard.js",
    "monitor:continuous": "node src/monitoring/dashboard.js continuous",
    "monitor:report": "node src/monitoring/dashboard.js report",
    "health": "node src/monitoring/health-check.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "test:unit": "NODE_OPTIONS=--experimental-vm-modules jest tests/unit",
    "test:integration": "NODE_OPTIONS=--experimental-vm-modules jest tests/integration",
    "test:coverage": "NODE_OPTIONS=--experimental-vm-modules jest --coverage",
    "lint": "eslint src/ tests/",
    "lint:fix": "eslint src/ tests/ --fix",
    "prepare": "husky",
    "vps:deploy": "./deploy-to-tpp-vps.sh",
    "vps:update": "ssh tpp-vps 'cd ~/projects/seo-expert && git pull && npm ci --omit=dev --ignore-scripts && pm2 restart seo-expert'",
    "vps:health": "ssh tpp-vps 'curl -sf http://localhost:3000/health && echo \"✓ SEO Expert healthy\" || echo \"✗ Health check failed\"'",
    "vps:logs": "ssh tpp-vps 'pm2 logs seo-expert --lines 50 --nostream'",
    "vps:status": "ssh tpp-vps 'pm2 show seo-expert'",
    "vps:restart": "ssh tpp-vps 'pm2 restart seo-expert'",
    "vps:connect": "ssh tpp-vps",
    "vps:monitor": "ssh tpp-vps 'pm2 monit'",
    "vps:backup": "ssh tpp-vps 'cd ~/projects/seo-expert && tar -czf ~/backups/seo-expert/manual-backup-$(date +%Y%m%d-%H%M%S).tar.gz --exclude=node_modules --exclude=.git .'",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop all",
    "pm2:restart": "pm2 restart all",
    "pm2:reload": "pm2 reload all",
    "pm2:logs": "pm2 logs",
    "pm2:monit": "pm2 monit",
    "pm2:status": "pm2 status",
    "pm2:save": "pm2 save",
    "actions:status": "echo 'Check: https://github.com/Theprofitplatform/seoexpert/actions'",
    "actions:logs": "gh run list --limit 5 || echo 'Install gh CLI: https://cli.github.com/'"
  },
  "keywords": [
    "seo",
    "wordpress",
    "automation",
    "monitoring",
    "schema",
    "rankings"
  ],
  "author": "Instant Auto Traders",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.67.0",
    "@googleapis/searchconsole": "^5.0.0",
    "axios": "^1.6.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^11.0.0",
    "cheerio": "^1.0.0-rc.12",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cron-parser": "^5.4.0",
    "date-fns": "^4.1.0",
    "dotenv": "^16.3.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.2.1",
    "googleapis": "^164.1.0",
    "helmet": "^8.1.0",
    "html-to-text": "^9.0.5",
    "http-proxy-middleware": "^3.0.5",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "mysql2": "^3.6.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.10",
    "openai": "^6.6.0",
    "pdfkit": "^0.17.2",
    "react-day-picker": "^9.11.1",
    "socket.io": "^4.7.5",
    "winston": "^3.14.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@babel/preset-react": "^7.28.5",
    "@jest/globals": "^30.2.0",
    "@playwright/test": "^1.56.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^29.5.0",
    "babel-jest": "^30.2.0",
    "chai": "^6.2.0",
    "eslint": "^8.50.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.2.0",
    "jsdom": "^27.0.1",
    "lint-staged": "^16.2.4",
    "lucide-react": "^0.552.0",
    "playwright": "^1.56.1",
    "supertest": "^7.1.4"
  }
}
