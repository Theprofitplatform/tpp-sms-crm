# SEO Automation Environment Variables
# Copy this to .env and fill in your actual values

# AI APIs (Required)
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-openai-key-here

# WordPress Credentials (Required for post optimization)
# Generate application passwords from WordPress Admin → Users → Application Passwords

# Instant Auto Traders
IAT_WP_USER=admin
IAT_WP_PASSWORD=your-wordpress-app-password-here

# Hot Tyres
HOTTYRES_WP_USER=admin
HOTTYRES_WP_PASSWORD=your-wordpress-app-password-here

# SADC Disability Services
SADC_WP_USER=admin
SADC_WP_PASSWORD=your-wordpress-app-password-here

# The Profit Platform (Not WordPress - can leave blank)
TPP_WP_USER=
TPP_WP_PASSWORD=

# SerpBear Integration (Optional - for rank tracking)
SERPBEAR_URL=https://serpbear.theprofitplatform.com.au
SERPBEAR_TOKEN=your-serpbear-token-here

# Google Search Console
# Service account JSON is in config/google/service-account.json
# No env var needed for local use - file is loaded directly

# ==================================
# NEW: SEO AUTOMATION PLATFORM v2.0
# ==================================

# Server Configuration
PORT=3000
NODE_ENV=development

# Email Configuration (SMTP)
# Choose your SMTP provider:

# Option 1: Gmail (for development/testing)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password  # Get from https://myaccount.google.com/apppasswords

# Option 2: SendGrid (recommended for production)
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=apikey
# SMTP_PASS=SG.your-sendgrid-api-key

# Option 3: AWS SES
# SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-aws-smtp-username
# SMTP_PASS=your-aws-smtp-password

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Email Sender Information
FROM_EMAIL=hello@yourcompany.com
FROM_NAME=Your Company Name
REPLY_TO_EMAIL=support@yourcompany.com
COMPANY_NAME=Your Company Name
SUPPORT_EMAIL=support@yourcompany.com
SUPPORT_PHONE=(555) 123-4567

# Company Address (CAN-SPAM Compliance)
# Required for commercial emails - must be valid physical mailing address
COMPANY_ADDRESS=123 Main Street
COMPANY_CITY=San Francisco
COMPANY_STATE=CA
COMPANY_ZIP=94102

# URLs
DASHBOARD_URL=http://localhost:3000

# Security
JWT_SECRET=change-this-to-a-random-secret-in-production
JWT_EXPIRES_IN=7d

# Database
DATABASE_PATH=./data/seo-automation.db

# ==================================
# PHASE 1 AUTOMATION FEATURES
# ==================================

# Discord Notifications
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/your-webhook-id/your-webhook-token
DISCORD_NOTIFICATIONS_ENABLED=true

# Automation Schedule (cron format: minute hour day month weekday)
RANK_TRACKING_ENABLED=true
RANK_TRACKING_SCHEDULE=0 6 * * *
LOCAL_SEO_ENABLED=true
LOCAL_SEO_SCHEDULE=0 7 * * *
LOCAL_SEO_AUTO_FIX=true
EMAIL_QUEUE_SCHEDULE=*/15 * * * *

# PDF Reports
PDF_STORAGE_PATH=./data/reports
PDF_MAX_SIZE_MB=10
