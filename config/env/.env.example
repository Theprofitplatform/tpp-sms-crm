# WordPress Site Configuration
WORDPRESS_URL=https://clientsite.com
WORDPRESS_USER=cloudcode
WORDPRESS_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# cPanel Deployment Credentials (Optional - for automated deployment)
CPANEL_URL=https://your-domain.com:2083
CPANEL_USER=your_username
CPANEL_PASS=your_password

# Google APIs
GOOGLE_PAGESPEED_API_KEY=xxxx
GOOGLE_SEARCH_CONSOLE_API_KEY=xxxx
GOOGLE_ANALYTICS_API_KEY=xxxx
GOOGLE_GEMINI_API_KEY=xxxx

# Competitor Analysis APIs (Choose one or more)
SERPAPI_KEY=xxxx
BING_WEBMASTER_API_KEY=xxxx
VALUESERP_API_KEY=xxxx
DATAFORSEO_LOGIN=your_email
DATAFORSEO_PASSWORD=your_password

# AI Content Optimization APIs (Choose one or more)
OPENAI_API_KEY=sk-proj-xxxx
ANTHROPIC_API_KEY=sk-ant-xxxx
COHERE_API_KEY=xxxx

# Automation Settings
AUTO_FIX_ENABLED=false
MAX_POSTS_PER_RUN=100
MIN_CONTENT_LENGTH=300

# Reporting & Notifications
REPORT_EMAIL=admin@example.com
NOTION_API_KEY=
NOTION_DATABASE_ID=
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/YOUR_WEBHOOK_ID/YOUR_WEBHOOK_TOKEN

# Safety Settings
APPLY_TO_PUBLISHED=false
DRY_RUN=true
LOG_LEVEL=info
